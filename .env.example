# Template for docker-compose.yml's variable substitution.
# Copy to .env (repo root) and fill in — docker compose reads .env from the
# same directory as docker-compose.yml, not from apps/api/.env.

POSTGRES_USER=foundryhq
POSTGRES_PASSWORD=foundryhq
POSTGRES_DB=foundryhq

PGADMIN_DEFAULT_EMAIL=dev@foundryhq.dev
PGADMIN_DEFAULT_PASSWORD=foundryhq
