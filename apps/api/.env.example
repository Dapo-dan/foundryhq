# Template for apps/api's environment config. Copy to apps/api/.env and fill in.

ENV=development
PORT=8080

# Matches docker-compose.yml's postgres service (mapped to 5434 on the host
# to avoid colliding with a locally-installed Postgres on 5432)
DB_HOST=localhost
DB_PORT=5434
DB_USER=foundryhq
DB_PASSWORD=foundryhq
DB_NAME=foundryhq
DB_SSLMODE=disable

# JWT — see docs/architecture.md's Auth Flow and adr/0004-jwt-access-refresh-tokens.md
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# OAuth — deferred to v1.1+ per docs/mvp.md, not needed for Version 1
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=

# CORS — comma-separated list of exact origins allowed to call the API
# (the web app's dev/prod URLs). Must be explicit origins, not "*" — the
# refresh-token cookie requires AllowCredentials, which CORS forbids
# combining with a wildcard origin.
CORS_ALLOWED_ORIGINS=http://localhost:5173
